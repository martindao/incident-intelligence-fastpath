{
  "name": "repo-01-incident-intelligence-fastpath",
  "version": "1.0.0",
  "description": "Incident Intelligence Fast-Path Console — Application Support flagship repo",
  "scripts": {
    "start:app": "node app-under-test/api/server.js",
    "start:worker": "node app-under-test/worker/index.js",
    "start:intelligence": "node intelligence-core/engine.js",
    "start:console": "node support-console/server.js",
    "start:all": "concurrently -n api,worker,intel,console -c blue,green,yellow,magenta \"npm run start:app\" \"npm run start:worker\" \"npm run start:intelligence\" \"npm run start:console\"",
    "scenario:poison-pill": "node scenarios/poison-pill-job/inject.js",
    "scenario:queue-backlog": "node scenarios/queue-backlog/inject.js",
    "scenario:db-exhaustion": "node scenarios/db-connection-exhaustion/inject.js",
    "reset": "node scripts/reset.js",
    "test": "node tests/run-tests.js",
    "test:integration": "node tests/integration.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["incident-management", "application-support", "support-engineering", "incident-intelligence"],
  "author": "Martin Dao",
  "license": "MIT"
}
